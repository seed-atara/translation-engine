# Database (Railway Postgres — copy from Railway dashboard)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Asana OAuth (register app at developers.asana.com)
ASANA_CLIENT_ID=""
ASANA_CLIENT_SECRET=""
ASANA_REDIRECT_URI="http://localhost:3000/api/asana/callback"

# Internal agency PAT (alternative to OAuth for single-agency setup)
ASANA_PAT=""

# File upload limits
MAX_UPLOAD_SIZE_MB="20"

# Feature flags
ENABLE_EXTENDED_THINKING="false"  # Enable for technical document translations (adds latency)
